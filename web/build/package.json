  "scripts": {
    "start": "npm i",
    "dev": "npm run fix && cross-env TNF_ENV=test  node --max-old-space-size=8192 build/fork.js",
    "dev2": "npm run fix && cross-env TNF_ENV=test  node --max-old-space-size=8192 build/dev-server.js",
    "build": "npm run fix && cross-env TNF_ENV=test  node build/build.js",
    "lint": "eslint --ext .js,.vue bin build config src ",
    "jtest": "jest --coverage",
    "stylelint": "stylelint --fix",
    "fix": "npm run lint -- --fix",
    "tnfusion": "node bin/tnfusion/main.js",
    "tnfusion-init": "node bin/tnfusion-init/main.js",
    "tnfusion-run": "node bin/tnfusion-run/main.js",
    "version": " git add .",
    "pubtnpm": "npm version patch && git push && tnpm publish && npm publish"
  },
  "keywords": [
    "TNFusion"
  ],
  "files": [
    "bin",
    "build",
    "docs"
  ],
  "bin": {
